```cpp
vector<int> answer_items;
int curr_w = W;
for (int i = n; i > 0; --i) {
    if (dp[i][curr_w] != dp[i-1][curr_w]) {
        answer_items.push_back(i); 
        curr_w -= w[i-1];
    }
}
